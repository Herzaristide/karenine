# KDE Color Scheme — generated by paletted — do not edit by hand.
# To change the accent, run: palette set "#rrggbb"
# Accent: @ACCENT@

[ColorScheme]
Name=AccentSync

# ── Buttons ─────────────────────────────────────────────────────────────
[Colors:Button]
BackgroundAlternate=@BASE01_RGB@
BackgroundNormal=@BASE01_RGB@
DecorationFocus=@ACCENT_RGB@
DecorationHover=@ACCENT_RGB@
ForegroundActive=@BASE05_RGB@
ForegroundInactive=@BASE04_RGB@
ForegroundLink=@ACCENT_RGB@
ForegroundNegative=@BASE08_RGB@
ForegroundNeutral=@BASE0A_RGB@
ForegroundNormal=@BASE05_RGB@
ForegroundPositive=@BASE0B_RGB@
ForegroundVisited=@BASE0E_RGB@

# ── Complementary (used by some panel widgets) ────────────────────────────
[Colors:Complementary]
BackgroundAlternate=@BASE01_RGB@
BackgroundNormal=@BASE00_RGB@
DecorationFocus=@ACCENT_RGB@
DecorationHover=@ACCENT_RGB@
ForegroundActive=@BASE05_RGB@
ForegroundInactive=@BASE04_RGB@
ForegroundLink=@ACCENT_RGB@
ForegroundNegative=@BASE08_RGB@
ForegroundNeutral=@BASE0A_RGB@
ForegroundNormal=@BASE05_RGB@
ForegroundPositive=@BASE0B_RGB@
ForegroundVisited=@BASE0E_RGB@

# ── Header bar (title bar, toolbar) ─────────────────────────────────────
[Colors:Header]
BackgroundAlternate=@BASE01_RGB@
BackgroundNormal=@BASE01_RGB@
DecorationFocus=@ACCENT_RGB@
DecorationHover=@ACCENT_RGB@
ForegroundActive=@BASE05_RGB@
ForegroundInactive=@BASE04_RGB@
ForegroundLink=@ACCENT_RGB@
ForegroundNegative=@BASE08_RGB@
ForegroundNeutral=@BASE0A_RGB@
ForegroundNormal=@BASE05_RGB@
ForegroundPositive=@BASE0B_RGB@
ForegroundVisited=@BASE0E_RGB@

# ── Selection ────────────────────────────────────────────────────────────
[Colors:Selection]
BackgroundAlternate=@ACCENT_DARK_RGB@
BackgroundNormal=@ACCENT_RGB@
DecorationFocus=@ACCENT_RGB@
DecorationHover=@ACCENT_RGB@
ForegroundActive=255,255,255
ForegroundInactive=200,200,220
ForegroundLink=200,230,255
ForegroundNegative=220,100,100
ForegroundNeutral=220,180,100
ForegroundNormal=255,255,255
ForegroundPositive=100,200,180
ForegroundVisited=180,130,220

# ── Tooltips ─────────────────────────────────────────────────────────────
[Colors:Tooltip]
BackgroundAlternate=@BASE00_RGB@
BackgroundNormal=@BASE01_RGB@
DecorationFocus=@ACCENT_RGB@
DecorationHover=@ACCENT_RGB@
ForegroundActive=@BASE05_RGB@
ForegroundInactive=@BASE04_RGB@
ForegroundLink=@ACCENT_RGB@
ForegroundNegative=@BASE08_RGB@
ForegroundNeutral=@BASE0A_RGB@
ForegroundNormal=@BASE05_RGB@
ForegroundPositive=@BASE0B_RGB@
ForegroundVisited=@BASE0E_RGB@

# ── File / list view ─────────────────────────────────────────────────────
[Colors:View]
BackgroundAlternate=@BASE01_RGB@
BackgroundNormal=@BASE00_RGB@
DecorationFocus=@ACCENT_RGB@
DecorationHover=@ACCENT_RGB@
ForegroundActive=@BASE05_RGB@
ForegroundInactive=@BASE04_RGB@
ForegroundLink=@ACCENT_RGB@
ForegroundNegative=@BASE08_RGB@
ForegroundNeutral=@BASE0A_RGB@
ForegroundNormal=@BASE05_RGB@
ForegroundPositive=@BASE0B_RGB@
ForegroundVisited=@BASE0E_RGB@

# ── Window / sidebar / panel ─────────────────────────────────────────────
[Colors:Window]
BackgroundAlternate=@BASE01_RGB@
BackgroundNormal=@BASE00_RGB@
DecorationFocus=@ACCENT_RGB@
DecorationHover=@ACCENT_RGB@
ForegroundActive=@BASE05_RGB@
ForegroundInactive=@BASE04_RGB@
ForegroundLink=@ACCENT_RGB@
ForegroundNegative=@BASE08_RGB@
ForegroundNeutral=@BASE0A_RGB@
ForegroundNormal=@BASE05_RGB@
ForegroundPositive=@BASE0B_RGB@
ForegroundVisited=@BASE0E_RGB@

# ── General ──────────────────────────────────────────────────────────────
[General]
ColorScheme=AccentSync
Name=AccentSync
shadeSortColumn=true

[KDE]
contrast=4
widgetStyle=breeze

# ── Window manager decorations ───────────────────────────────────────────
[WM]
activeBackground=@BASE01_RGB@
activeBlend=@BASE00_RGB@
activeForeground=@BASE05_RGB@
inactiveBackground=@BASE00_RGB@
inactiveBlend=@BASE00_RGB@
inactiveForeground=@BASE04_RGB@

# ── Icons ─────────────────────────────────────────────────────────────────
[Icons]
Theme=@ICONS_THEME@
