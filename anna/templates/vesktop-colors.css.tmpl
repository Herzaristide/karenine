/* Generated by paletted -- do not edit.
   Written directly to ~/.config/vesktop/settings/quickCss.css.
   Reload Vesktop (Ctrl+R) after paletted runs to apply changes. */

:root,
.theme-dark,
.theme-light,
.theme-darker,
.theme-midnight {
  /* Legacy Discord brand variables (still used on older surfaces) */
  --brand-experiment:     @ACCENT@;
  --brand-experiment-500: @ACCENT@;
  --brand-experiment-560: @ACCENT@;
  --brand-experiment-600: @ACCENT_DARK@;
  --brand-500: @ACCENT@;
  --brand-560: @ACCENT@;
  --brand-600: @ACCENT_DARK@;
  --text-link: @ACCENT_MUTED@;
}

/* Friends panel: "Add Friend" tab + childWrapper buttons.
   Discord hardcodes #5865F2 on these, so we target the class. */
[class*="addFriend__"],
[class*="childWrapper__"],
[class*="childWrapperNoHoverBg__"] {
  background-color: @ACCENT@ !important;
  color: #ffffff !important;
}
[class*="addFriend__"]:hover,
[class*="childWrapper__"]:hover {
  background-color: @ACCENT_DARK@ !important;
}

/* Inline-style fallback: anything literally styled with Discord blurple. */
[style*="#5865F2"],
[style*="#5865f2"],
[style*="rgb(88, 101, 242)"] {
  background-color: @ACCENT@ !important;
  color: #ffffff !important;
}
